  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Send OTP",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}, {"key": "Accept", "value": "application/json"}],
            "url": {"raw": "{{baseUrl}}/send-otp", "host": ["{{baseUrl}}"], "path": ["send-otp"]},
            "body": {"mode": "raw", "raw": "{\n  \"phone_number\": \"+919999999999\",\n  \"country_code\": \"+91\"\n}"}
          }
        },
        {
          "name": "Verify OTP",
          "event": [{"listen": "test", "script": {"exec": ["var r = pm.response.json(); if(r.success && r.data && r.data.token){ pm.collectionVariables.set('token', r.data.token); }"]}}],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}, {"key": "Accept", "value": "application/json"}],
            "url": {"raw": "{{baseUrl}}/verify-otp", "host": ["{{baseUrl}}"], "path": ["verify-otp"]},
            "body": {"mode": "raw", "raw": "{\n  \"phone_number\": \"+919999999999\",\n  \"country_code\": \"+91\",\n  \"otp\": \"252600\",\n  \"verification_id\": \"{{verificationId}}\"\n}"}
          }
        },
        {
          "name": "Social Login (Google/Apple)",
          "event": [{"listen": "test", "script": {"exec": ["var r = pm.response.json(); if(r.success && r.data && r.data.token){ pm.collectionVariables.set('token', r.data.token); }"]}}],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}, {"key": "Accept", "value": "application/json"}],
            "url": {"raw": "{{baseUrl}}/social-login", "host": ["{{baseUrl}}"], "path": ["social-login"]},
            "body": {"mode": "raw", "raw": "{\n  \"login_type\": \"google\",\n  \"email\": \"user@example.com\",\n  \"full_name\": \"Test User\",\n  \"profile_pic\": \"\",\n  \"uid\": \"google_uid_here\"\n}"}
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [{"key": "Accept", "value": "application/json"}, {"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": {"raw": "{{baseUrl}}/logout", "host": ["{{baseUrl}}"], "path": ["logout"]}
          }
        },
        {
          "name": "Delete Account",
          "request": {
            "method": "DELETE",
            "header": [{"key": "Accept", "value": "application/json"}, {"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": {"raw": "{{baseUrl}}/delete-account", "host": ["{{baseUrl}}"], "path": ["delete-account"]}
          }
        }
      ]
    },
