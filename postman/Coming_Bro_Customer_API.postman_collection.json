          "name": "Check Profile Exists",
          "request": {
            "method": "GET",
            "header": [{"key": "Accept", "value": "application/json"}],
            "url": {"raw": "{{baseUrl}}/profile/check-exists?phone_number=%2B919999999999", "host": ["{{baseUrl}}"], "path": ["profile", "check-exists"]}
